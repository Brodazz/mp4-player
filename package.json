{
  "name": "mp4-player",
  "displayName": "Modern Video Player — with Audio (MP4, MKV, HEVC)",
  "description": "Play MP4, MKV, MOV, M4V, AVI, M2TS, FLV and HEVC/H.265 videos with sound — right in a VS Code tab. Real audio (even AAC) with zero setup: ffmpeg is bundled (WebAssembly), no install, no local server, fully offline. HEVC is converted to H.264 on the fly. Lightweight, secure, one universal package.",
  "version": "0.8.2",
  "license": "MIT",
  "publisher": "Brodazz",
  "icon": "assets/icon.png",
  "author": {
    "name": "Alessandro Broda"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Brodazz/mp4-player.git"
  },
  "bugs": {
    "url": "https://github.com/Brodazz/mp4-player/issues"
  },
  "homepage": "https://github.com/Brodazz/mp4-player#readme",
  "keywords": [
    "video player",
    "mp4 player",
    "mkv player",
    "mov player",
    "video preview",
    "play video",
    "mp4",
    "mkv",
    "mov",
    "m4v",
    "avi",
    "matroska",
    "flv player",
    "avchd",
    "m2ts",
    "hevc",
    "h265",
    "h.265",
    "video",
    "player",
    "audio",
    "sound",
    "subtitles",
    "srt",
    "mp4 audio",
    "video with sound",
    "aac",
    "ffmpeg",
    "webassembly",
    "wasm",
    "media",
    "preview",
    "quicktime",
    "h264"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "qna": "https://github.com/Brodazz/mp4-player/issues",
  "pricing": "Free",
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mp4Player.preview",
        "displayName": "Video Player",
        "selector": [
          {
            "filenamePattern": "*.mp4"
          },
          {
            "filenamePattern": "*.mov"
          },
          {
            "filenamePattern": "*.m4v"
          },
          {
            "filenamePattern": "*.mkv"
          },
          {
            "filenamePattern": "*.avi"
          },
          {
            "filenamePattern": "*.m2ts"
          },
          {
            "filenamePattern": "*.mts"
          },
          {
            "filenamePattern": "*.flv"
          },
          {
            "filenamePattern": "*.f4v"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && node --test out/media.test.js",
    "package": "vsce package"
  },
  "dependencies": {
    "@ffmpeg.wasm/core-st": "^0.13.2",
    "@ffmpeg.wasm/main": "^0.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  }
}
