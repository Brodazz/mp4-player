{
  "name": "mp4-player",
  "displayName": "Modern Video Player — with Audio (MP4, MKV, MOV)",
  "description": "Play MP4, MKV, MOV, M4V and AVI videos with sound — right in a VS Code tab. Real audio (even AAC) with zero setup: ffmpeg is bundled (WebAssembly), no install, no local server, fully offline. Lightweight, secure, one universal package.",
  "version": "0.7.0",
  "license": "MIT",
  "publisher": "Brodazz",
  "icon": "assets/icon.png",
  "author": {
    "name": "Alessandro Broda"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Brodazz/mp4-player.git"
  },
  "bugs": {
    "url": "https://github.com/Brodazz/mp4-player/issues"
  },
  "homepage": "https://github.com/Brodazz/mp4-player#readme",
  "keywords": [
    "video player",
    "mp4 player",
    "mkv player",
    "mov player",
    "video preview",
    "play video",
    "mp4",
    "mkv",
    "mov",
    "m4v",
    "avi",
    "matroska",
    "video",
    "player",
    "audio",
    "sound",
    "subtitles",
    "srt",
    "mp4 audio",
    "video with sound",
    "aac",
    "ffmpeg",
    "webassembly",
    "wasm",
    "media",
    "preview",
    "quicktime",
    "h264"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "qna": "https://github.com/Brodazz/mp4-player/issues",
  "pricing": "Free",
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mp4Player.preview",
        "displayName": "Video Player",
        "selector": [
          {
            "filenamePattern": "*.mp4"
          },
          {
            "filenamePattern": "*.mov"
          },
          {
            "filenamePattern": "*.m4v"
          },
          {
            "filenamePattern": "*.mkv"
          },
          {
            "filenamePattern": "*.avi"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "@ffmpeg.wasm/core-st": "^0.13.2",
    "@ffmpeg.wasm/main": "^0.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  }
}
