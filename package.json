{
  "name": "mp4-player",
  "displayName": "Modern Video Player — with Audio (MP4, MKV, HEVC, WebM)",
  "description": "Play videos with sound in a VS Code tab — real audio out of the box (even AAC), with zero setup and no ffmpeg to install. MP4, MKV, MOV, M4V, AVI, M2TS, FLV, WebM and HEVC/H.265. ffmpeg is bundled (WebAssembly): no install, no local server, fully offline. HEVC and VP9/VP8 are converted to H.264 on the fly. Subtitles, audio boost, loop and frame capture included. Lightweight, secure, one universal package.",
  "version": "0.8.5",
  "license": "MIT",
  "publisher": "Brodazz",
  "icon": "assets/icon.png",
  "author": {
    "name": "Alessandro Broda"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Brodazz/mp4-player.git"
  },
  "bugs": {
    "url": "https://github.com/Brodazz/mp4-player/issues"
  },
  "homepage": "https://github.com/Brodazz/mp4-player#readme",
  "keywords": [
    "video player",
    "mp4 player",
    "mkv player",
    "mov player",
    "video preview",
    "play video",
    "mp4",
    "mkv",
    "mov",
    "m4v",
    "avi",
    "matroska",
    "flv player",
    "avchd",
    "m2ts",
    "hevc",
    "h265",
    "h.265",
    "webm",
    "webm player",
    "vp9",
    "audio boost",
    "loop",
    "video",
    "player",
    "audio",
    "sound",
    "subtitles",
    "srt",
    "mp4 audio",
    "video with sound",
    "aac",
    "ffmpeg",
    "webassembly",
    "wasm",
    "media",
    "preview",
    "quicktime",
    "h264"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "qna": "https://github.com/Brodazz/mp4-player/issues",
  "pricing": "Free",
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mp4Player.preview",
        "displayName": "Video Player",
        "selector": [
          {
            "filenamePattern": "*.mp4"
          },
          {
            "filenamePattern": "*.mov"
          },
          {
            "filenamePattern": "*.m4v"
          },
          {
            "filenamePattern": "*.mkv"
          },
          {
            "filenamePattern": "*.avi"
          },
          {
            "filenamePattern": "*.m2ts"
          },
          {
            "filenamePattern": "*.mts"
          },
          {
            "filenamePattern": "*.flv"
          },
          {
            "filenamePattern": "*.f4v"
          },
          {
            "filenamePattern": "*.webm"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && node --test out/media.test.js",
    "package": "vsce package"
  },
  "dependencies": {
    "@ffmpeg.wasm/core-st": "^0.13.2",
    "@ffmpeg.wasm/main": "^0.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  }
}
