{
  "name": "mp4-player",
  "displayName": "Modern Video Player — with Audio (MP4, MOV, M4V)",
  "description": "Modern video player with audio for VS Code — play MP4, MOV and M4V with sound out of the box. No ffmpeg to install, no server, fully offline.",
  "version": "0.6.0",
  "license": "MIT",
  "publisher": "Brodazz",
  "icon": "assets/icon.png",
  "author": {
    "name": "Alessandro Broda"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Brodazz/mp4-player.git"
  },
  "bugs": {
    "url": "https://github.com/Brodazz/mp4-player/issues"
  },
  "homepage": "https://github.com/Brodazz/mp4-player#readme",
  "keywords": [
    "video player",
    "mp4 player",
    "mp4",
    "mov",
    "m4v",
    "video",
    "player",
    "audio",
    "sound",
    "play video",
    "media",
    "preview",
    "quicktime",
    "h264"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mp4Player.preview",
        "displayName": "Video Player",
        "selector": [
          {
            "filenamePattern": "*.mp4"
          },
          {
            "filenamePattern": "*.mov"
          },
          {
            "filenamePattern": "*.m4v"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "@ffmpeg.wasm/core-st": "^0.13.2",
    "@ffmpeg.wasm/main": "^0.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  }
}
